# ===== Threadly Backend Environment Variables =====
# انسخ هذا الملف إلى .env واملأ القيم

# ===== AI Provider =====
# اختر واحد فقط من المزودين المجانيين:
AI_PROVIDER=groq

# Groq - مجاني وسريع جداً
# احصل على المفتاح من: https://console.groq.com
GROQ_API_KEY=

# Gemini - مجاني من Google
# احصل على المفتاح من: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Ollama - يعمل محلياً (لا يحتاج API key)
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# ===== Security =====
SECRET_KEY=your-very-long-random-secret-key-change-this

# ===== الاشتراكات والتاجر =====
# القيم الافتراضية لأول تشغيل فقط - بعدها تُدار من لوحة الأدمن
# عبر PUT /api/admin/settings (تُحفظ في جدول platform_settings).
DEFAULT_FREE_TRIAL_ENABLED=true     # تشغيل الفترة التجريبية المجانية مبدئياً
DEFAULT_FREE_TRIAL_DAYS=14          # مدة التجربة المجانية بالأيام
DEFAULT_MONTHLY_PRICE=9.99          # سعر الاشتراك الشهري
DEFAULT_MONTHLY_PERIOD_DAYS=30      # طول الشهر (الاشتراك المدفوع)
SUBSCRIPTION_CURRENCY=USD

# إيميلات تُمنح صلاحية الأدمن تلقائياً عند الإقلاع (للتحكم بالإعدادات).
# مثال: ADMIN_EMAILS=["admin@threadly.app"]
ADMIN_EMAILS=[]

# ===== Firebase (اختياري - للـ Push Notifications) =====
# لو فاضي، تعمل الإشعارات اللحظية عبر WebSocket فقط (بدون Push للخلفية).
# FIREBASE_CREDENTIALS_PATH=/path/to/serviceAccount.json

# ===== Database =====
# للتشغيل المحلي باستخدام Docker (افتراضي)
# DATABASE_URL=postgresql://threadly:threadly_dev_password@postgres:5432/threadly_db

# للتشغيل على Railway (استخدم هذا الرابط)
# DATABASE_URL=postgresql://postgres:JOBIrKrtzUBXMCXuabJPrqsjxwOgvtqU@postgres.railway.internal:5432/railway

# ===== Redis =====
# للتشغيل المحلي باستخدام Docker
# REDIS_URL=redis://redis:6379/0